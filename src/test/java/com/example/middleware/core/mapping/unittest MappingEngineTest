@Test
public void test_default_value() {

    Map<String, Object> payload = new HashMap<>();
    payload.put("Item_Code", "A002");

    RawEvent event = new RawEvent(
            "EVT002",
            "PROFILE_1",
            "HQ_Price_Master",
            payload
    );

    FieldRule rule = new FieldRule();
    rule.setSourceField("Base_Price");
    rule.setTargetField("PRICE");
    rule.setDefaultValue("9999");
    rule.setDataType("INTEGER");

    TableRule tableRule = new TableRule();
    tableRule.setSourceTable("HQ_Price_Master");
    tableRule.setTargetTable("POS");
    tableRule.setFieldRules(List.of(rule));

    MappingContext context = new MappingContext();
    context.addRule("HQ_Price_Master", tableRule);

    MappingEngine engine = new MappingEngine();

    TransformedEvent result = engine.transform(event, context);

    assertEquals(9999, result.getPayload().get("PRICE"));
}
