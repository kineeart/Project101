   @Test
    public void test_full_mapping_pipeline() {

        // =========================
        // 1. RAW EVENT (INPUT)
        // =========================
        Map<String, Object> payload = new HashMap<>();
        payload.put("Item_Code", "A001");
        payload.put("Base_Price", "10000");

        RawEvent event = new RawEvent(
                "EVT001",
                "PROFILE_1",
                "HQ_Price_Master",
                payload
        );

        // =========================
        // 2. FIELD RULE
        // =========================
        FieldRule rule1 = new FieldRule();
        rule1.setSourceField("Item_Code");
        rule1.setTargetField("ITEM_ID");
        rule1.setDataType("STRING");

        FieldRule rule2 = new FieldRule();
        rule2.setSourceField("Base_Price");
        rule2.setTargetField("PRICE");
        rule2.setDataType("INTEGER");

        List<FieldRule> rules = Arrays.asList(rule1, rule2);

        // =========================
        // 3. TABLE RULE
        // =========================
        TableRule tableRule = new TableRule();
        tableRule.setSourceTable("HQ_Price_Master");
        tableRule.setTargetTable("POS_Price_Target");
        tableRule.setFieldRules(rules);

        // =========================
        // 4. CONTEXT
        // =========================
        MappingContext context = new MappingContext();
        context.addRule("HQ_Price_Master", tableRule);

        // =========================
        // 5. EXECUTE ENGINE
        // =========================
        MappingEngine engine = new MappingEngine();

        TransformedEvent result = engine.transform(event, context);

        // =========================
        // 6. ASSERTIONS
        // =========================
        assertEquals("PROFILE_1", result.getProfileId());
        assertEquals("POS_Price_Target", result.getTargetTable());

        assertEquals("A001", result.getPayload().get("ITEM_ID"));
        assertEquals(10000, result.getPayload().get("PRICE"));
    }
